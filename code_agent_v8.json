      "parameters": {
        "chatId": "6517856768",
        "text": "❌ Fix rechazado. Archivo restaurado al original.",
        "additionalFields": {}
      },
      "credentials": { "telegramApi": { "name": "11Mkeys Code Bot" } },
      "position": [940, 440]
    },
    {
      "name": "Status Check",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "parameters": {
        "resource": "command",
        "command": "cd /opt/crypto_agent_system && docker compose ps --format 'table {{.Name}}\\t{{.Status}}' && echo '---HOLDER DATA---' && docker compose exec -T postgres psql -U postgres -d crypto_agent -c \"SELECT COUNT(*) as con_holder_data FROM token_candidates WHERE holder_concentration_pct IS NOT NULL AND status='active';\" 2>/dev/null"
      },
      "credentials": { "sshPassword": { "name": "VPS Hostinger" } },
      "position": [940, 600]
    },
    {
      "name": "Send Status",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "parameters": {
        "chatId": "6517856768",
        "text": "=📊 *Estado Criminal Pumps*\n\n```\n{{ $json.stdout }}\n```",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "credentials": { "telegramApi": { "name": "11Mkeys Code Bot" } },
      "position": [1160, 600]
    },
    {
      "name": "Logs Check",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "parameters": {
        "resource": "command",
        "command": "cd /opt/crypto_agent_system && docker compose logs --tail 30 2>&1 | grep -E 'ERROR|WARNING|error|warning|critical' | tail -20 || echo 'Sin errores encontrados'"
      },
      "credentials": { "sshPassword": { "name": "VPS Hostinger" } },
      "position": [940, 720]
    },
    {
      "name": "Send Logs",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "parameters": {
        "chatId": "6517856768",
        "text": "=🪵 *Logs con errores (últimos 30)*\n\n```\n{{ $json.stdout ? $json.stdout.substring(0, 3500) : 'Sin errores encontrados ✅' }}\n```",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "credentials": { "telegramApi": { "name": "11Mkeys Code Bot" } },
      "position": [1160, 720]
    },
    {
      "name": "Scores Check",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "parameters": {
        "resource": "command",
        "command": "cd /opt/crypto_agent_system && docker compose exec -T postgres psql -U postgres -d crypto_agent -c \"SELECT symbol, total_score, holder_concentration_pct, volume_24h_usd FROM token_candidates WHERE status='active' ORDER BY total_score DESC LIMIT 10;\" 2>/dev/null || echo 'Sin datos disponibles'"
      },
      "credentials": { "sshPassword": { "name": "VPS Hostinger" } },
      "position": [940, 860]
    },
    {
      "name": "Send Scores",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "parameters": {
        "chatId": "6517856768",
        "text": "=🏆 *Top 10 tokens por score*\n\n```\n{{ $json.stdout ? $json.stdout.substring(0, 3500) : 'Sin datos disponibles' }}\n```",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "credentials": { "telegramApi": { "name": "11Mkeys Code Bot" } },
      "position": [1160, 860]
    },
    {
      "name": "SD Execute Command",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "parameters": {
        "resource": "command",
        "command": "CMD=$(timeout 5 docker exec crypto_agent_system-redis-1 redis-cli GET smartdevops:pending_command) && if [ -z \"$CMD\" ]; then echo 'No hay comando pendiente en Redis'; else echo \"Ejecutando: $CMD\" && bash -c \"$CMD\" 2>&1 | head -20 && timeout 5 docker exec crypto_agent_system-redis-1 redis-cli DEL smartdevops:pending_command && echo '---EJECUTADO---'; fi"
      },
      "credentials": { "sshPassword": { "name": "VPS Hostinger" } },
      "position": [700, 1020]
    },
    {
      "name": "SD Notify Executed",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "parameters": {
        "chatId": "6517856768",
        "text": "=✅ *SmartDevops — Comando ejecutado*\n\n```\n{{ $json.stdout ? $json.stdout.substring(0, 2000) : 'Sin output' }}\n```",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "credentials": { "telegramApi": { "name": "11Mkeys Code Bot" } },
      "position": [940, 1020]
    },
    {
      "name": "SD Ignore Command",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "parameters": {
        "resource": "command",
        "command": "timeout 5 docker exec crypto_agent_system-redis-1 redis-cli DEL smartdevops:pending_command && echo 'Comando ignorado y eliminado de Redis'"
      },
      "credentials": { "sshPassword": { "name": "VPS Hostinger" } },
      "position": [700, 1160]
    },
    {
      "name": "SD Notify Ignored",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "parameters": {
        "chatId": "6517856768",
        "text": "❌ *SmartDevops — Propuesta ignorada*\n\nEl comando fue descartado.",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "credentials": { "telegramApi": { "name": "11Mkeys Code Bot" } },
      "position": [940, 1160]
    }
  ],
  "connections": {
    "Telegram Trigger": {
      "main": [[{ "node": "Route Command", "type": "main", "index": 0 }]]
