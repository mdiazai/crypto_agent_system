# ═══════════════════════════════════════════════════════════════════
#  CRYPTO AGENT SYSTEM — Variables de Entorno
#  Copia este archivo a .env y completa los valores reales.
#  NUNCA subas .env a git.
# ═══════════════════════════════════════════════════════════════════

# ── AI / LLM ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Exchange: MEXC ────────────────────────────────────────────────
MEXC_API_KEY=mx0vXXXXXXXXXXXXXXXXXXXX
MEXC_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Exchange: Bitget ──────────────────────────────────────────────
BITGET_API_KEY=bg_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BITGET_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BITGET_PASSPHRASE=XXXXXXXXXXXXXXXX

# ── Telegram ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TELEGRAM_CHAT_ID=-1001234567890

# ── On-Chain APIs ─────────────────────────────────────────────────
GLASSNODE_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ETHERSCAN_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SOLSCAN_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── CoinGecko / CoinMarketCap ─────────────────────────────────────
COINGECKO_API_KEY=CG-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
COINMARKETCAP_API_KEY=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# ── Base de Datos ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/crypto_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=crypto_agent

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Auth (Dashboard) ──────────────────────────────────────────
JWT_SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_ALEATORIA_DE_32_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=CAMBIA_ESTO

# ── Scheduler ─────────────────────────────────────────────────────
DISCOVERY_SCHEDULE_HOUR=2          # Hora UTC para ejecutar Discovery (default: 2am)
MONITOR_INTERVAL_SECONDS=300       # Intervalo de monitoreo (default: 5 min)
LEARNER_SCHEDULE_HOUR=3            # Hora UTC para ejecutar Learner (default: 3am)

# ── Capital y Distribución ────────────────────────────────────────
CAPITAL_TOTAL_USD=1000.0
MEXC_ALLOCATION_PCT=69
BITGET_ALLOCATION_PCT=31

# ── Umbrales de Detección ─────────────────────────────────────────
ALERT_THRESHOLD=70                 # Score mínimo para generar alerta
LLM_VALIDATION_THRESHOLD=85       # Score mínimo para validación con Claude
INFLOW_THRESHOLD_USD=500000        # Inflow mínimo considerado significativo (USD)
HOLDER_CONCENTRATION_THRESHOLD=60  # % supply en top-10 wallets para activar señal
SHORT_INTEREST_THRESHOLD=20        # % float en short para patrón Classic

# ── Gestión de Riesgo ─────────────────────────────────────────────
STOP_LOSS_PCT=8                    # % de caída para stop loss automático
TAKE_PROFIT_1_PCT=30               # % de ganancia para vender 50%
TAKE_PROFIT_2_PCT=60               # % de ganancia para vender 30%
TAKE_PROFIT_3_PCT=100              # % de ganancia para vender 20% restante
MAX_DAILY_LOSS_PCT=15              # % máximo de pérdida diaria antes de pausar
MAX_CONSECUTIVE_LOSSES=3          # Pérdidas consecutivas antes de circuit breaker
CIRCUIT_BREAKER_HOURS=24          # Horas de pausa tras circuit breaker

# ── Modo de Operación ─────────────────────────────────────────────
PAPER_TRADING=true                 # true = simular trades; false = trading real
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR

# ── Observabilidad ────────────────────────────────────────────────
SENTRY_DSN=https://XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX@oXXXXXX.ingest.sentry.io/XXXXXXX
PROMETHEUS_PORT=8000
GRAFANA_PORT=3000
